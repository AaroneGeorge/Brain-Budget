# Chain selection: baseSepolia (dev, free) | base (mainnet demo)
CHAIN=baseSepolia

# RPC endpoints (public defaults work; replace with your own for reliability)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Burner private keys — generate fresh ones, never reuse real wallets.
# USER = the delegator (fund with USDC). AGENT = the delegate (the research agent).
# GATEWAY = the tools-server wallet that receives x402 payments and pays Venice.
USER_PRIVATE_KEY=0x...
AGENT_PRIVATE_KEY=0x...
GATEWAY_PRIVATE_KEY=0x...

# Tools server
SERVER_PORT=4021
SERVER_URL=http://localhost:4021

# Public URL the 1Shot relayer POSTs task status webhooks to — a tunnel of
# POST /relayer/webhook (e.g. `ngrok http 4021`). Empty = fall back to polling.
RELAYER_WEBHOOK_URL=

# Venice (mainnet only — paid via x402 from the GATEWAY wallet, no API key needed)
VENICE_MODEL=llama-3.3-70b
VENICE_PLANNING_MODEL=qwen3-4b
CRITIC_PRIVATE_KEY=0x... # A2A critic burner
